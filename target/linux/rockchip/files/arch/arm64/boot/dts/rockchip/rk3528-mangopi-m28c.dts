/dts-v1/;
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/pwm/pwm.h>

#include "rk3528-mangopi-m28.dtsi"

/ {
	model = "Widora MangoPi M28C";
	compatible = "widora,mangopi-m28c", "rockchip,rk3528";

	chosen {
		stdout-path = "serial0:1500000n8";
	};

	gpio-export {
		compatible = "gpio-export";
		#size-cells = <0>;

		modem_reset {
			gpio-export,name = "MODEM-RST";
			gpio-export,output = <0>;
			gpios = <&gpio4 RK_PA3 GPIO_ACTIVE_LOW>;
		};

		modem_power {
			gpio-export,name = "MODEM-PWR";
			gpio-export,output = <1>;
			gpios = <&gpio4 RK_PB1 GPIO_ACTIVE_HIGH>;
		};
	};

	fan: fan {
		compatible = "pwm-fan";//pwm3
		cooling-levels = <0 100 150 200 255>;
		#cooling-cells = <2>;
		pwms = <&pwm3 0 1000000 0>;
	};
};

&pinctrl {
	bt {
		bt_reg_on_h: bt-reg-on-h {
			rockchip,pins = <1 RK_PC1 RK_FUNC_GPIO &pcfg_pull_up>;
		};

		bt_wake_host_h: bt-wake-host-h {
			rockchip,pins = <1 RK_PC2 RK_FUNC_GPIO &pcfg_pull_down>;
		};

		host_wake_bt_h: host-wake-bt-h {
			rockchip,pins = <1 RK_PB4 RK_FUNC_GPIO &pcfg_pull_down>;
		};
	};

	gmac {
		gmac1_rstn_l: gmac1-rstn-l {
			rockchip,pins = <4 RK_PC2 RK_FUNC_GPIO &pcfg_pull_down>;
		};
	};

	gpio-leds {
		work_led_pin: work-led-pin {
			rockchip,pins = <4 RK_PB7 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	sdmmc {
		sdmmc_vol_ctrl_h: sdmmc-vol-ctrl-h {
			rockchip,pins = <4 RK_PB6 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	wifi {
		wifi_reg_on_h: wifi-reg-on-h {
			rockchip,pins = <1 RK_PA6 RK_FUNC_GPIO &pcfg_pull_down>;
		};

		wifi_wake_host_h: wifi-wake-host-h {
			rockchip,pins = <1 RK_PA7 RK_FUNC_GPIO &pcfg_pull_down>;
		};
	};
};

&pwm3 {
	pinctrl-names = "default";
	pinctrl-0 = <&pwm3m0_pins>;
	status = "okay";
};

&soc_thermal {
	trips {
		cpu_passive: cpu_passive {
			temperature = <45000>;
			hysteresis = <2000>;
			type = "active";
		};

		cpu_active: cpu_active {
			temperature = <55000>;
			hysteresis = <2000>;
			type = "active";
		};

		cpu_warm: cpu_warm {
			temperature = <65000>;
			hysteresis = <2000>;
			type = "active";
		};

		cpu_hot: cpu_hot {
			temperature = <75000>;
			hysteresis = <2000>;
			type = "active";
		};
	};

	cooling-maps {
		map1 {
			trip = <&cpu_passive>;
			cooling-device = <&fan 0 1>;
		};

		map2 {
			trip = <&cpu_active>;
			cooling-device = <&fan 1 2>;
		};

		map3 {
			trip = <&cpu_warm>;
			cooling-device = <&fan 2 3>;
		};

		map4 {
			trip = <&cpu_hot>;
			cooling-device = <&fan 3 4>;
		};
	};
};

&usb_host0_xhci {
	dr_mode = "host";
	maximum-speed = "super-speed";
	phys = <&usb2phy_otg>, <&combphy PHY_TYPE_USB3>;
	phy-names = "usb2-phy", "usb3-phy";
	snps,dis_u2_susphy_quirk;
	status = "okay";
};
