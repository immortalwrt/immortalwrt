/dts-v1/;

#include "mt7981a.dtsi"

/ {
	model = "Aigo AGS21";
	compatible = "aigo,ags21", "mediatek,mt7981";

	aliases {
		serial0 = &uart0;
		led-boot = &led_red;
		led-failsafe = &led_red;
		led-running = &led_blue;
		led-upgrade = &led_blue;
	};

	chosen {
		bootargs = "console=ttyS0,115200n1 root=PARTLABEL=rootfs rootwait";
	};

	memory {
		reg = <0x40000000 0x20000000>;
	};

	gpio-keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			gpios = <&pio 1 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
		};

		mesh {
			label = "mesh";
			gpios = <&pio 0 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_WPS_BUTTON>;
		};
	};

	leds {
		compatible = "gpio-leds";

		led_red: led-0 {
			label = "red:status";
			gpios = <&pio 6 GPIO_ACTIVE_LOW>;
		};

		led_blue: led-1 {
			label = "blue:status";
			gpios = <&pio 4 GPIO_ACTIVE_LOW>;
		};

		led-2 {
			label = "green:internet";
			gpios = <&pio 29 GPIO_ACTIVE_LOW>;
		};

		led-3 {
			label = "yellow:wifi";
			gpios = <&pio 30 GPIO_ACTIVE_LOW>;
		};
	};
};

&uart0 {
	status = "okay";
};

&uart1 {
	status = "disabled";
};

&uart2 {
	status = "disabled";
};

&eth {
	status = "okay";

	gmac0: mac@0 {
		compatible = "mediatek,eth-mac";
		reg = <0>;
		phy-mode = "2500base-x";
		phy-handle = <&phy0>;
		nvmem-cells = <&macaddr_factory_4>;
		nvmem-cell-names = "mac-address";
	};

	mdio-bus {
		#address-cells = <1>;
		#size-cells = <0>;

		phy0: ethernet-phy@0 {
			reg = <0>;
			reset-gpios = <&pio 15 GPIO_ACTIVE_LOW>;
			reset-assert-us = <10000>;
			reset-deassert-us = <20000>;
			phy-mode = "2500base-x";
		};
	};
};

&hnat {
	mtketh-wan = "eth0";
	mtketh-lan = "lan";
};

&mmc0 {
	pinctrl-names = "default", "state_uhs";
	pinctrl-0 = <&mmc0_pins_default>;
	pinctrl-1 = <&mmc0_pins_uhs>;
	bus-width = <8>;
	max-frequency = <200000000>;
	cap-mmc-highspeed;
	mmc-hs200-1_8v;
	mmc-hs400-1_8v;
	non-removable;
	status = "okay";

	card@0 {
		compatible = "mmc-card";
		reg = <0>;

		block {
			compatible = "block-device";

			partitions {
				#address-cells = <2>;
				#size-cells = <2>;

				partition@0 {
					label = "u-boot-env";
					reg = <0x0 0x80000>;
					read-only;
				};

				partition@80000 {
					label = "factory";
					reg = <0x80000 0x200000>;
					read-only;
				};

				partition@280000 {
					label = "fip";
					reg = <0x280000 0x200000>;
					read-only;
				};

				partition@480000 {
					label = "kernel";
					reg = <0x480000 0x2000000>;
				};

				partition@2480000 {
					label = "rootfs";
					reg = <0x2480000 0x80000000>;
				};

				partition@82480000 {
					label = "data";
					reg = <0x82480000 0xe0000000>;
				};
			};

			nvmem-layout {
				compatible = "fixed-layout";
				#address-cells = <1>;
				#size-cells = <1>;

				eeprom@0 {
					reg = <0x0 0x1000>;
				};

				macaddr_factory_4: macaddr@4 {
					reg = <0x4 0x6>;
				};

				macaddr_factory_24: macaddr@24 {
					reg = <0x24 0x6>;
				};

				macaddr_factory_2a: macaddr@2a {
					reg = <0x2a 0x6>;
				};

				macaddr_factory_30: macaddr@30 {
					reg = <0x30 0x6>;
				};
			};
		};
	};
};

&wifi {
	status = "okay";
	mediatek,mtd-eeprom = <&factory 0x0>;
};

&usb_phy {
	status = "okay";
};

&usb {
	status = "okay";
	vusb33-supply = <&reg_3p3v>;
};
